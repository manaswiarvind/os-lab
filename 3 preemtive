
#include <stdio.h>
#define MAX 100

struct Process {
    int id, bt, deadline, period, share;
    int ct, wt, tat;
};

// -------- Reset --------
void reset(struct Process p[], int n) {
    for (int i = 0; i < n; i++)
        p[i].ct = p[i].wt = p[i].tat = 0;
}

// -------- EDF --------
void EDF(struct Process p[], int n) {
    printf("\n--- EDF Scheduling ---\n");

    // sort by deadline
    for (int i = 0; i < n-1; i++)
        for (int j = 0; j < n-i-1; j++)
            if (p[j].deadline > p[j+1].deadline) {
                struct Process t = p[j];
                p[j] = p[j+1];
                p[j+1] = t;
            }

    int time = 0;
    printf("Gantt: ");
    for (int i = 0; i < n; i++) {
        printf("| P%d ", p[i].id);
        p[i].wt = time;
        time += p[i].bt;
        p[i].ct = time;
        p[i].tat = p[i].ct;
    }
    printf("|\n");

    printf("ID\tBT\tDL\tCT\tWT\tTAT\n");
    for (int i = 0; i < n; i++)
        printf("%d\t%d\t%d\t%d\t%d\t%d\n",
            p[i].id, p[i].bt, p[i].deadline,
            p[i].ct, p[i].wt, p[i].tat);
}

// -------- RMS --------
void RMS(struct Process p[], int n) {
    printf("\n--- RMS Scheduling ---\n");

    // sort by period (priority)
    for (int i = 0; i < n-1; i++)
        for (int j = 0; j < n-i-1; j++)
            if (p[j].period > p[j+1].period) {
                struct Process t = p[j];
                p[j] = p[j+1];
                p[j+1] = t;
            }

    int time = 0;
    printf("Gantt: ");
    for (int i = 0; i < n; i++) {
        printf("| P%d ", p[i].id);
        p[i].wt = time;
        time += p[i].bt;
        p[i].ct = time;
        p[i].tat = p[i].ct;
    }
    printf("|\n");

    printf("ID\tBT\tPR\tCT\tWT\tTAT\n");
    for (int i = 0; i < n; i++)
        printf("%d\t%d\t%d\t%d\t%d\t%d\n",
            p[i].id, p[i].bt, p[i].period,
            p[i].ct, p[i].wt, p[i].tat);
}

// -------- Proportional Share --------
void PS(struct Process p[], int n) {
    printf("\n--- Proportional Share ---\n");

    int rem[MAX], done = 0, time = 0;
    for (int i = 0; i < n; i++) rem[i] = p[i].bt;

    printf("Gantt: ");

    while (done < n) {
        for (int i = 0; i < n; i++) {
            if (rem[i] > 0 && p[i].share > 0) {

                int slice = p[i].share; // weight-based slice
                if (slice > rem[i]) slice = rem[i];

                printf("| P%d ", p[i].id);

                rem[i] -= slice;
                time += slice;

                if (rem[i] == 0) {
                    p[i].ct = time;
                    p[i].tat = p[i].ct;
                    p[i].wt = p[i].tat - p[i].bt;
                    done++;
                }
            }
        }
    }
    printf("|\n");

    printf("ID\tBT\tSH\tCT\tWT\tTAT\n");
    for (int i = 0; i < n; i++)
        printf("%d\t%d\t%d\t%d\t%d\t%d\n",
            p[i].id, p[i].bt, p[i].share,
            p[i].ct, p[i].wt, p[i].tat);
}

// -------- MAIN --------
int main() {
    int n;
    struct Process p[MAX];

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        p[i].id = i;
        printf("\nP%d\nBT: ", i);
        scanf("%d", &p[i].bt);
        printf("Deadline: ");
        scanf("%d", &p[i].deadline);
        printf("Period: ");
        scanf("%d", &p[i].period);
        printf("Share: ");
        scanf("%d", &p[i].share);
    }

    reset(p, n); EDF(p, n);
    reset(p, n); RMS(p, n);
    reset(p, n); PS(p, n);

    return 0;
}
