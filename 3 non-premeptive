#include <stdio.h>
#define MAX 100

struct Process {
    int id, bt, deadline, period, share;
    int ct, wt, tat;
};

// -------- Reset --------
void reset(struct Process p[], int n) {
    for (int i = 0; i < n; i++)
        p[i].ct = p[i].wt = p[i].tat = 0;
}

// -------- EDF --------
void EDF(struct Process p[], int n) {
    printf("\n--- Preemptive EDF ---\n");

    int rem[MAX], complete = 0, time = 0;

    for (int i = 0; i < n; i++)
        rem[i] = p[i].bt;

    printf("Gantt: ");

    while (complete < n) {
        int idx = -1;

        for (int i = 0; i < n; i++) {
            if (rem[i] > 0) {
                if (idx == -1 || p[i].deadline < p[idx].deadline)
                    idx = i;
            }
        }

        if (idx != -1) {
            printf("| P%d ", p[idx].id);

            rem[idx]--;
            time++;

            if (rem[idx] == 0) {
                p[idx].ct = time;
                p[idx].tat = p[idx].ct;
                p[idx].wt = p[idx].tat - p[idx].bt;
                complete++;
            }
        }
    }
    printf("|\n");

    // Table
    printf("ID\tBT\tDL\tCT\tWT\tTAT\n");
    for (int i = 0; i < n; i++) {
        printf("%d\t%d\t%d\t%d\t%d\t%d\n",
            p[i].id, p[i].bt, p[i].deadline,
            p[i].ct, p[i].wt, p[i].tat);
    }
}

// -------- RMS --------
void RMS(struct Process p[], int n) {
    printf("\n--- Preemptive RMS ---\n");

    int rem[MAX], complete = 0, time = 0;

    for (int i = 0; i < n; i++)
        rem[i] = p[i].bt;

    printf("Gantt: ");

    while (complete < n) {
        int idx = -1;

        for (int i = 0; i < n; i++) {
            if (rem[i] > 0) {
                if (idx == -1 || p[i].period < p[idx].period)
                    idx = i;
            }
        }

        if (idx != -1) {
            printf("| P%d ", p[idx].id);

            rem[idx]--;
            time++;

            if (rem[idx] == 0) {
                p[idx].ct = time;
                p[idx].tat = p[idx].ct;
                p[idx].wt = p[idx].tat - p[idx].bt;
                complete++;
            }
        }
    }
    printf("|\n");

    // Table
    printf("ID\tBT\tPR\tCT\tWT\tTAT\n");
    for (int i = 0; i < n; i++) {
        printf("%d\t%d\t%d\t%d\t%d\t%d\n",
            p[i].id, p[i].bt, p[i].period,
            p[i].ct, p[i].wt, p[i].tat);
    }
}

// -------- Proportional Share --------
void PS(struct Process p[], int n) {
    printf("\n--- Preemptive Proportional Share ---\n");

    int rem[MAX], complete = 0, time = 0;

    for (int i = 0; i < n; i++)
        rem[i] = p[i].bt;

    printf("Gantt: ");

    while (complete < n) {
        for (int i = 0; i < n; i++) {
            if (rem[i] > 0) {

                printf("| P%d ", p[i].id);

                rem[i]--;
                time++;

                if (rem[i] == 0) {
                    p[i].ct = time;
                    p[i].tat = p[i].ct;
                    p[i].wt = p[i].tat - p[i].bt;
                    complete++;
                }
            }
        }
    }
    printf("|\n");

    // Table
    printf("ID\tBT\tSH\tCT\tWT\tTAT\n");
    for (int i = 0; i < n; i++) {
        printf("%d\t%d\t%d\t%d\t%d\t%d\n",
            p[i].id, p[i].bt, p[i].share,
            p[i].ct, p[i].wt, p[i].tat);
    }
}

// -------- MAIN --------
int main() {
    int n;
    struct Process p[MAX];

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        p[i].id = i;
        printf("\nP%d\nBT: ", i);
        scanf("%d", &p[i].bt);
        printf("Deadline: ");
        scanf("%d", &p[i].deadline);
        printf("Period: ");
        scanf("%d", &p[i].period);
        printf("Share: ");
        scanf("%d", &p[i].share);
    }

    reset(p, n); EDF(p, n);
    reset(p, n); RMS(p, n);
    reset(p, n); PS(p, n);

    return 0;
}

